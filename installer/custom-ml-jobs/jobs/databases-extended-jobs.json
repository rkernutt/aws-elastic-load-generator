          "detectors": [
            {
              "detector_description": "High mean DynamoDB successful request latency by table",
              "function": "high_mean",
              "field_name": "aws.dynamodb.metrics.SuccessfulRequestLatency.avg",
              "partition_field_name": "aws.dynamodb.table.name",
              "detector_index": 0
            }
          ],
          "influencers": [
            "aws.dynamodb.table.name"
          ]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
